{
  "expo": {
    "name": "90 Days Recovery Tracker",
    "slug": "90-days-recovery-tracker",
    "version": "1.5.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-ninety-days.png",
    "scheme": "ninetydaysrecovery",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ninetydays.recoverytracker",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Get a daily reminder to check in and stay on track."
      }
    },
    "android": {
      "package": "com.ninetydays.recoverytracker",
      "versionCode": 3,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon-ninety-days-android-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "iosDisplayInForeground": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon-ninety-days.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8840b376-e098-4f9c-9fc1-798b8ca88f1b"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8840b376-e098-4f9c-9fc1-798b8ca88f1b"
    }
  }
}
